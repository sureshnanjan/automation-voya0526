{
  "name": "Playwright Training",
  "image": "mcr.microsoft.com/playwright:v1.54.0-noble",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-playwright.playwright",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next"
